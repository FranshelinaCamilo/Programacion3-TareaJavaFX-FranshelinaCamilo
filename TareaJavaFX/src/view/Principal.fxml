            </items>
          </Menu>
        </menus>
      </MenuBar>
      <Label fx:id="lblTitulo" alignment="CENTER" layoutX="118.0" layoutY="147.0" prefHeight="68.0" prefWidth="362.0" style="-fx-font-weight: bold;" text="Bienvenido al Sistema de Registro de Paquetes y Destinos" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="System Bold Italic" size="16.0" />
         </font>
      </Label>
      <Label fx:id="lblMensajes" alignment="CENTER" contentDisplay="CENTER" layoutX="190.0" layoutY="252.0" prefHeight="58.0" prefWidth="219.0" text="..." textAlignment="CENTER" wrapText="true" />
   </children>
</Pane>
